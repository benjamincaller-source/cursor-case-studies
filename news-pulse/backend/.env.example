PORT=3001

# Optionnel — enrichit les résultats avec NewsAPI (https://newsapi.org)
NEWS_API_KEY=

# Optionnel — active la recherche X/Twitter (https://developer.x.com)
X_BEARER_TOKEN=

# Optionnel — résumés IA via OpenAI (https://platform.openai.com)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Intervalle de vérification des nouveaux articles pour le push (ms, défaut: 15 min)
POLL_INTERVAL_MS=900000

# Désactiver le mode démo (données fictives si sources indisponibles)
# DEMO_MODE=false
